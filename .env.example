# PulsePage service config
NODE_ENV=production
PULSEPAGE_HOST=127.0.0.1
PULSEPAGE_PORT=4177
PULSEPAGE_CHECK_EVERY_MS=60000
PULSEPAGE_SCHEDULER_ENABLED=true
# Optional custom paths
# PULSEPAGE_DATA_DIR=/var/lib/pulsepage
# PULSEPAGE_DB_FILE=/var/lib/pulsepage/pulsepage.sqlite

# Required in production to protect add/delete/manual-check API actions
PULSEPAGE_ADMIN_TOKEN=change-this-long-random-token
